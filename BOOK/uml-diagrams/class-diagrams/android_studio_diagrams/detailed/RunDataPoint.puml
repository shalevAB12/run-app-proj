@startuml
class RunDataPoint {
    - latitude : double
    - longitude : double
    - altitude : double
    - speed : float
    - timestamp : long
    - accuracy : float
    - stepDelta : int
    - isFirstPoint : boolean
    + RunDataPoint()
    + RunDataPoint(latitude : double, longitude : double, altitude : double, speed : float, timestamp : long, accuracy : float, stepDelta : int, isFirstPoint : boolean)
    + getLatitude() : double
    + getLongitude() : double
    + getAltitude() : double
    + getSpeed() : float
    + getTimestamp() : long
    + getAccuracy() : float
    + getStepDelta() : int
    + isFirstPoint() : boolean
}
@enduml